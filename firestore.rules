rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: usuário autenticado
    function authed() {
      return request.auth != null;
    }

    // Helper: dados do próprio usuário no Firestore
    function userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    // Helper: usuário é admin
    function isAdmin() {
      return authed() && userDoc().perfil == 'admin' && userDoc().ativo == true;
    }

    // ─────────────────────────────────────────────────────────────────
    // USUARIOS
    // ─────────────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      // Ler: o próprio user, ou um admin
      allow read: if authed() && (request.auth.uid == uid || isAdmin());

      // Listar: somente admin
      allow list: if isAdmin();

      // Criar: somente admin (ou seed inicial - desativar após setup)
      allow create: if isAdmin();

      // Atualizar: o próprio user (limitado a senha_temp/ultimo_acesso) ou admin (tudo)
      allow update: if isAdmin()
        || (authed() && request.auth.uid == uid
            && request.resource.data.diff(resource.data).changedKeys()
                .hasOnly(['senha_temp', 'ultimo_acesso']));

      // Deletar: somente admin
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────
    // PERFIS TEMPLATE
    // ─────────────────────────────────────────────────────────────────
    match /perfisTemplate/{key} {
      allow read: if authed();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────
    // CONFIG (metas_gpc etc.)
    // ─────────────────────────────────────────────────────────────────
    match /config/{doc} {
      // Ler: qualquer user autenticado
      allow read: if authed();
      // Escrever: somente admin (metas só admin edita)
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────────────
    // AUDIT LOG
    // ─────────────────────────────────────────────────────────────────
    match /auditLog/{id} {
      // Criar: qualquer user autenticado (sistema escreve eventos)
      allow create: if authed();
      // Ler/listar: somente admin
      allow read, list: if isAdmin();
      // Não permite update/delete
      allow update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────
    // FALLBACK · negar tudo o que não foi declarado
    // ─────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
